SITELEADS_EMBED_CODE=
TEAM_ATTRIBUTION_USERNAME=
TEAM_ATTRIBUTION_PASSWORD=
GOOGLE_SITE_VERIFICATION=
BING_SITE_VERIFICATION=

# Lead email delivery (SMTP — works with Microsoft 365, Google Workspace,
# SendGrid/Postmark/Mailgun SMTP, etc.)
# Production form submissions fail closed unless SMTP_HOST, SMTP_USER, and
# SMTP_PASSWORD are configured, so leads are not silently dropped.
# Microsoft 365 example: smtp.office365.com / 587 / office@allsberryagency.com
# Google Workspace example: smtp.gmail.com / 587 / office@allsberryagency.com (app password)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
LEADS_TO_EMAIL=office@allsberryagency.com
LEADS_FROM_EMAIL=office@allsberryagency.com

# Analytics (GA4 + Google Ads)
NEXT_PUBLIC_GA4_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_LABEL=

# AggregateRating rich-snippet (confirmed Google review totals only)
AGENCY_REVIEW_COUNT=
AGENCY_REVIEW_RATING=
